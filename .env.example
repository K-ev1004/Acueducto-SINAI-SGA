# =============================================================================
# SINAÍ SGA - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores
# NUNCA hagas commit del archivo .env con valores reales

# =============================================================================
# SEGURIDAD - OBLIGATORIO
# =============================================================================

# Clave secreta de Django (mínimo 50 caracteres, usar: python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_SECRET_KEY=cambia-esta-clave-por-una-segura-de-al-menos-50-caracteres

# Modo debug (False en producción)
DEBUG=True

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# BASE DE DATOS
# =============================================================================

DB_NAME=sinai_db
DB_USER=postgres
DB_PASSWORD=tu-contraseña-segura
DB_HOST=localhost
DB_PORT=5432

# =============================================================================
# CORS - Frontend
# =============================================================================

FRONTEND_URL=http://localhost:3000

# =============================================================================
# NOTAS DE SEGURIDAD
# =============================================================================
# 1. Generate a new SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(50))"
#
# 2. En producción:
#    - DEBUG=False
#    - Usar HTTPS
#    - Configurar ALLOWED_HOSTS con tu dominio real
#    - DB_PASSWORD debe ser una contraseña segura de PostgreSQL
# =============================================================================